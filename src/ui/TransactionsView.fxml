<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="ui.TransactionsController"
      spacing="15"
      alignment="CENTER"
      style="-fx-background-color:#f4f6f9;">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Transactions">
        <font>
            <Font size="22"/>
        </font>
    </Label>

    <TableView fx:id="transactionTable" prefWidth="600" prefHeight="400">

        <columns>

            <TableColumn fx:id="dateColumn" text="Date" prefWidth="120"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="120"/>
            <TableColumn fx:id="categoryColumn" text="Category" prefWidth="150"/>
            <TableColumn fx:id="amountColumn" text="Amount" prefWidth="120"/>
            <TableColumn fx:id="noteColumn" text="Note" prefWidth="200"/>

        </columns>

    </TableView>

    <Button fx:id="closeButton"
            text="Close"
            style="-fx-background-color:#f44336; -fx-text-fill:white;"/>

</VBox>