<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="ui.DashboardController"
      spacing="20"
      alignment="TOP_CENTER"
      style="-fx-background-color: #f4f6f8; -fx-padding: 30;">

    <Label fx:id="welcomeLabel"
           text="Welcome!"
           style="-fx-font-size: 24px; -fx-font-weight: bold;" />

    <HBox spacing="20" alignment="CENTER">

        <VBox alignment="CENTER"
              spacing="5"
              style="-fx-background-color: #4e73df; -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="Income" style="-fx-text-fill: white;" />
            <Label fx:id="incomeLabel"
                   text="\$0"
                   style="-fx-text-fill: white; -fx-font-size: 18px;" />
        </VBox>

        <VBox alignment="CENTER"
              spacing="5"
              style="-fx-background-color: #e74a3b; -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="Expenses" style="-fx-text-fill: white;" />
            <Label fx:id="expenseLabel"
                   text="\$0"
                   style="-fx-text-fill: white; -fx-font-size: 18px;" />
        </VBox>

        <VBox alignment="CENTER"
              spacing="5"
              style="-fx-background-color: #1cc88a; -fx-padding: 20; -fx-background-radius: 10;">
            <Label text="Balance" style="-fx-text-fill: white;" />
            <Label fx:id="balanceLabel"
                   text="\$0"
                   style="-fx-text-fill: white; -fx-font-size: 18px;" />
        </VBox>

    </HBox>

    <GridPane hgap="20" vgap="20" alignment="CENTER">

        <Button fx:id="addIncomeButton"
                text="Add Income"
                prefWidth="150" />

        <Button fx:id="addExpenseButton"
                text="Add Expense"
                prefWidth="150"
                GridPane.columnIndex="1" />

        <Button fx:id="viewReportsButton"
                text="View Reports"
                prefWidth="150"
                GridPane.rowIndex="1" />

        <Button fx:id="manageCategoriesButton"
                text="Manage Categories"
                prefWidth="150"
                GridPane.columnIndex="1"
                GridPane.rowIndex="1" />

    </GridPane>

</VBox>